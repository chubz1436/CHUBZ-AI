{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localhost.invalid/chubz/runtime-config-v1.schema.json",
  "title": "CHUBZ AI Command Center local runtime configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["configVersion", "controlPlane", "bridge", "paths", "bounds", "retention", "projects", "display"],
  "properties": {
    "configVersion": { "const": 1 },
    "controlPlane": {
      "type": "object", "additionalProperties": false,
      "required": ["host", "port", "allowedOrigin", "sessionSecretRef"],
      "properties": {
        "host": { "enum": ["127.0.0.1", "::1"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "allowedOrigin": { "type": "string", "maxLength": 2048 },
        "sessionSecretRef": { "type": "string", "pattern": "^environment:[A-Z][A-Z0-9_]{2,127}$" }
      }
    },
    "bridge": {
      "type": "object", "additionalProperties": false,
      "required": ["endpoint", "enrollmentIdentity", "heartbeatIntervalMs"],
      "properties": {
        "endpoint": { "type": "string", "maxLength": 2048 },
        "enrollmentIdentity": { "const": "local-bridge" },
        "heartbeatIntervalMs": { "type": "integer", "minimum": 1000, "maximum": 300000 }
      }
    },
    "paths": {
      "type": "object", "additionalProperties": false,
      "required": ["approvedManagedRoots", "managedDataRoot", "databaseFile", "logsDirectory", "supportBundlesDirectory", "packagesDirectory"],
      "properties": {
        "approvedManagedRoots": { "type": "array", "minItems": 1, "maxItems": 8, "items": { "type": "string", "maxLength": 2048 } },
        "managedDataRoot": { "type": "string", "maxLength": 2048 },
        "databaseFile": { "$ref": "#/$defs/safeName" },
        "logsDirectory": { "$ref": "#/$defs/safeName" },
        "supportBundlesDirectory": { "$ref": "#/$defs/safeName" },
        "packagesDirectory": { "$ref": "#/$defs/safeName" }
      }
    },
    "bounds": {
      "type": "object", "additionalProperties": false,
      "required": ["logMaxBytes", "logRetentionFiles", "captureMaxBytes", "packageMaxBytes", "packageMaxFiles", "supportBundleMaxBytes", "supportBundleMaxFiles", "storageWarningPercent"],
      "properties": {
        "logMaxBytes": { "type": "integer", "minimum": 65536, "maximum": 67108864 },
        "logRetentionFiles": { "type": "integer", "minimum": 1, "maximum": 32 },
        "captureMaxBytes": { "type": "integer", "minimum": 65536, "maximum": 268435456 },
        "packageMaxBytes": { "type": "integer", "minimum": 1048576, "maximum": 536870912 },
        "packageMaxFiles": { "type": "integer", "minimum": 1, "maximum": 20000 },
        "supportBundleMaxBytes": { "type": "integer", "minimum": 65536, "maximum": 33554432 },
        "supportBundleMaxFiles": { "type": "integer", "minimum": 1, "maximum": 256 },
        "storageWarningPercent": { "type": "integer", "minimum": 50, "maximum": 95 }
      }
    },
    "retention": {
      "type": "object", "additionalProperties": false,
      "required": ["operationalLogDays", "resolvedAlertDays", "supportBundleDays", "packagingStagingHours"],
      "properties": {
        "operationalLogDays": { "type": "integer", "minimum": 1, "maximum": 365 },
        "resolvedAlertDays": { "type": "integer", "minimum": 1, "maximum": 3650 },
        "supportBundleDays": { "type": "integer", "minimum": 1, "maximum": 365 },
        "packagingStagingHours": { "type": "integer", "minimum": 1, "maximum": 168 }
      }
    },
    "projects": { "type": "array", "maxItems": 64, "items": { "type": "object", "additionalProperties": false, "required": ["projectId", "managedCloneRoot"], "properties": { "projectId": { "$ref": "#/$defs/safeName" }, "managedCloneRoot": { "type": "string", "maxLength": 2048 } } } },
    "display": { "type": "object", "additionalProperties": false, "required": ["productName", "environmentLabel"], "properties": { "productName": { "type": "string", "minLength": 1, "maxLength": 256 }, "environmentLabel": { "type": "string", "minLength": 1, "maxLength": 256 } } }
  },
  "$defs": { "safeName": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" } }
}
